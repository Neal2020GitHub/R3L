from typing import List, Literal, Union, Iterator
from contextlib import contextmanager
from pydantic import BaseModel, Field

class Var:
    """
    Explicit parameter variable used in constraints.
    """
    def __init__(self, value: Union[float, str]):
        """
        Args:
            value: Parameter value or label.
{% if hv_absolute %}
                - Numeric value for clearance, x, y, distance, sweep_deg, angle.
{% else %}
                - Numeric value for clearance, percentile, distance, sweep_deg, angle.
{% endif %}
                - String label for alignment parameters: "backboard"/"center"/"frontboard" or "left"/"center"/"right"
        """
        pass

class Room(BaseModel):
    """
    Axis-aligned rectangular room.
    Origin (0, 0) is at bottom-left corner.
    """
    length: float = Field(description="Room length along X axis (meters)")
    width: float = Field(description="Room width along Y axis (meters)")

WallId = Literal[
    "L", # left wall (inward normal: face right)
    "R", # right wall (inward normal: face left)
    "T", # top wall (inward normal: face bottom)
    "B"  # bottom wall (inward normal: face top)
]

CornerId = Literal[
    "BL", # bottom-left corner
    "BR", # bottom-right corner
    "TR", # top-right corner
    "TL"  # top-left corner
]

class Asset(BaseModel):
    id: str = Field(description="Unique id for the asset")
    description: str = Field(description="Description of the asset")
    size: Tuple[float, float] = Field(description="2D footprint size of the asset (x, y) in meters")
{% if cognitive_map %}
    pose: Optional[Pose] = Field(default=None, description="Estimated pose. Local if in cluster, Global if independent.")
{%- endif %}

{% if clustered %}
class ClusterHandle(BaseModel):
    """
    Opaque handle representing a cluster in GLOBAL scope.
    """
    cluster_id: str = Field(description="Unique id for the cluster")
{% if cognitive_map %}
    aabb: Optional[AABB] = Field(default=None, description="Estimated Local Bounding Box of the cluster")
    pose: Optional[Pose] = Field(default=None, description="Global pose of the Anchor asset")
{%- endif %}

Entity = Union[Asset, ClusterHandle]
{% endif %}
{% set entity = "Asset" if not clustered else "Entity" -%}

{% if cognitive_map %}
class Pose(BaseModel): 
    x: float = Field(description="X coordinates of the entity's center")
    y: float = Field(description="Y coordinates of the entity's center")
    rz: float = Field(description="Rotation in degrees. Positive value means counter-clockwise from +Y")

{% if clustered %}
class AABB(BaseModel):
    """
    Axis-Aligned Bounding Box (in cluster Local Frame).
    Used to estimate the footprint of a cluster, for global pose estimation
    """
    lx: float = Field(description="Total Length along X axis (width)")
    ly: float = Field(description="Total Length along Y axis (height)")
{% endif %}

{% if volumetric_grounding %}
class Footprint(BaseModel):
    """
    Rotated bounding box dimensions (reasoning scaffold).

    Rotation rules (for original size sx, sy):
        rz in {0, 180}: lx=sx, ly=sy (NO SWAP)
        rz in {90, -90}: lx=sy, ly=sx (SWAP)
        other angles: lx = |sx*cos(rz)| + |sy*sin(rz)|
                      ly = |sx*sin(rz)| + |sy*cos(rz)|
    """
    rz: float = Field(description="Rotation angle (degrees). Must match intended pose.rz.")
    lx: float = Field(description="Footprint length along X-axis AFTER rotation.")
    ly: float = Field(description="Footprint length along Y-axis AFTER rotation.")

class Bounds(BaseModel):
    """
    Axis-aligned bounding box occupancy (collision scaffold).

    Derivation: Given pose center (cx, cy) and footprint (lx, ly):
        x_min, x_max = cx - lx/2, cx + lx/2
        y_min, y_max = cy - ly/2, cy + ly/2

    Collision: Two objects collide iff bounds overlap in BOTH x AND y.
    """
    x_min: float = Field(description="Minimum X coordinate of bounding box.")
    x_max: float = Field(description="Maximum X coordinate of bounding box.")
    y_min: float = Field(description="Minimum Y coordinate of bounding box.")
    y_max: float = Field(description="Maximum Y coordinate of bounding box.")
{% endif %}
{%- endif %}
```

